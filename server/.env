NODE_ENV=development

PORT=5050
# CORS Configuration - Allow all origins for network access
CORS_ORIGIN=*
MONGO_URI=mongodb://localhost:27017/online_recruit_system
# Use local MongoDB (Atlas blocked on your network). Run: docker run -d -p 27017:27017 --name mongo mongo
USE_LOCAL_MONGO=true
JWT_SECRET=supersecretjwtkeychangeme
ADMIN_SECRET_KEY=secrect123

# ============================================
# Email Configuration for Password Reset
# ============================================
# Option 1: Gmail SMTP (Recommended for production)
# For Gmail: Use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Steps:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select "Mail" and "Windows Computer"
#   4. Copy the 16-character password
#   5. Paste it below (remove any spaces)
EMAIL_USER=botteprashanthyadav@gmail.com
EMAIL_PASSWORD=ohzb ecdl vrig jfkt
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Option 2: Mailtrap (For development/testing)
# If Gmail authentication fails, set USE_MAILTRAP=true
# Get credentials from: https://mailtrap.io
# Steps:
#   1. Create account at https://mailtrap.io
#   2. Create a new inbox
#   3. Go to "Integrations" -> "Nodemailer"
#   4. Copy the username and password
#   5. Set them below and set USE_MAILTRAP=true
#  USE_MAILTRAP=false
# MAILTRAP_USER=your-mailtrap-username
# MAILTRAP_PASSWORD=your-mailtrap-password

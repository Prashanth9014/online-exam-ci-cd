# Server
NODE_ENV=development
PORT=5000

# Database (required in production)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
# Development only: use local MongoDB when Atlas is unreachable
# USE_LOCAL_MONGO=false

# Auth (min 32 chars in production)
JWT_SECRET=your-super-secret-key-at-least-32-characters-long

# Production: comma-separated frontend origins (e.g. https://app.example.com)
# CORS_ORIGIN=https://yourfrontend.com,https://www.yourfrontend.com
